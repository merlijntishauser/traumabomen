POSTGRES_USER=traumabomen
POSTGRES_PASSWORD=changeme
POSTGRES_DB=traumabomen
DATABASE_URL=postgresql+asyncpg://traumabomen:changeme@db:5432/traumabomen
JWT_SECRET_KEY=changeme-generate-a-real-key
JWT_ALGORITHM=HS256

# Email verification (disabled by default for local dev / self-hosted)
REQUIRE_EMAIL_VERIFICATION=false
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM=noreply@example.com
APP_BASE_URL=http://localhost:5173
APP_BASE_URL_NL=

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173

# Smoketest account for admin analytics exclusion and perf checks (optional)
SMOKETEST_EMAIL=
SMOKETEST_PASSWORD=

# Email address for feedback notifications (optional)
FEEDBACK_EMAIL=

# Beta waitlist (disabled by default)
ENABLE_WAITLIST=false
MAX_ACTIVE_USERS=20

# Sentry error tracking (disabled by default; leave DSN empty for local dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
VITE_SENTRY_DSN=
