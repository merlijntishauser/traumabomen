{
  "ignore": {
    "rules": ["react-doctor/rerender-state-only-in-handlers"],
    "overrides": [
      {
        "files": ["**/api.test.ts"],
        "rules": ["react-doctor/js-cache-storage"]
      },
      {
        "files": ["**/mailpit.ts"],
        "rules": [
          "react-doctor/async-await-in-loop",
          "react-doctor/js-index-maps",
          "react-doctor/js-set-map-lookups"
        ]
      },
      {
        "files": ["**/e2e/**"],
